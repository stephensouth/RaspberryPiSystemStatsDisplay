# Copy to .env and adjust for your wiring.
# All values are optional; defaults work for common setups.

# GPIO pin (BCM) for momentary button: press = start/restart display session
PI_STATS_BUTTON_GPIO=17
# Button polarity: 1 = active-low (GPIO to GND when pressed), 0 = active-high
PI_STATS_BUTTON_ACTIVE_LOW=1

# GPIO pin (BCM) for WS2812B data line. Pi 3/4: 18 (PWM). Pi 5: see README.
PI_STATS_LED_GPIO=18

# Number of WS2812B LEDs in the strip (e.g. 1 for single LED)
PI_STATS_LED_COUNT=1

# Rotate stat screens every N seconds
PI_STATS_SCREEN_ROTATE_SECONDS=4.2

# Session turns off after this many seconds total
PI_STATS_DISPLAY_IDLE_OFF=60

# I2C address of OLED (hex). Adafruit PiOLED is 0x3C.
PI_STATS_OLED_I2C_ADDR=0x3C

# Debug: 1 = start session immediately at launch (no button required)
PI_STATS_DEBUG_FORCE_MAIN_VIEW=0
